{
    "name": "sunnysideup/sitehost-cache-purge",
    "description": "Hooks a silverstripe install to the Sitehost Cache to Purge it",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "sitehost",
        "cache",
        "caching",
        "purge",
        "cdn",
        "clear cache",
        "speed",
        "optimised",
        "best hosting company in the world"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "silverstripe/admin": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sunnysideup\\SitehostCachePurge\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [],
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ]
}